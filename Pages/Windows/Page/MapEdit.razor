@using Apollo2.Shared.Sys.Data.Map
@using Apollo2.Sys
@using Apollo2.Sys.Windows
@using Apollo2.Sys.Data
@using Apollo2.Shared.Sys.Data.Incidents
@using Apollo2.Shared.Sys.User
@using Apollo2.Shared.Sys.Data.Units
@using System.Runtime.InteropServices.JavaScript;
@inject Incidents _incsService
@inject Units _unitsService
@inject HttpClient _http
@inject IJSRuntime JSRuntime

<div class="ROOT">

 <div class="HEADER">
  <div class="TITLE">
   Map Editor
  </div>
  <div class="CONTROLS">

   @if (status.StartsWith("ERROR"))
   {
    <div class="error">
     FAILED TO LOAD
    </div>
   } else
   {
    @switch (status)
    {
     case "DELPOI":
     case "CREATEPOI2":
     case "CREATELINE2":
      break;
      case "CREATEPOLY":
      {
       <button @onclick="createPoly">Cancel Poly</button>
       <button @onclick="savePoly">Save Poly</button>
       break;
      }
     case "CREATELINE":
      {
       <button @onclick="createLine">Cancel Line</button>
       <button @onclick="saveLine">Save Line</button>
       break;
      }
     case "CREATEPOI":
      {
        <button @onclick="createPOI">@(status == "CREATEPOI" ? "Cancel POI" : "Create POI")</button>
        break;
      }
     default:
      {
         <button @onclick="createPOI">Create POI</button>
         <button @onclick="createLine">Create Line Object</button>
         <button @onclick="createPoly">Create Poly Object</button>
         <button @onclick="openDelete">Manage Objects</button>
         break;
      }
    }
   }
   <button class="DISCARD" @onclick="discard">CLOSE</button>
  </div>
 </div>

 <div class="BODY">
   @switch(status)
   {
     case "CREATEPOI2":
     {
       <div class="SUBPANEL">
         <div class="SUBPANELHEADER">
           Creating new Point of Interest
         </div>
         <div class="SUBPANELBODY">
           Category <br />
           <select @bind="poiSelectedCategory">
             @foreach(POICategory category in categories)
              {
               <option value="@category.name">@category.name</option>
              }
           </select>
           <br />

           Name<br />
           <input type="text" @bind-value="poiName" />
           <br />
           Display Name<br />
           <input type="text" @bind-value="poiShortName" />
           <br />
           <button class="SAVE" @onclick="poiSave">Save</button>
           <button class="DISCARD" @onclick="poiCancel">Cancel</button>

         </div>
       </div>
     break;
    }

    case "CREATELINE2":
     {
       <div class="SUBPANEL">
         <div class="SUBPANELHEADER">
           Creating new Line
         </div>
         <div class="SUBPANELBODY">
           Category (Utilizes background color) <br />
           <select @bind="poiSelectedCategory">
             @foreach(POICategory category in categories)
              {
               <option value="@category.name">@category.name</option>
              }
           </select>
           <br />
           Name<br />
           <input type="text" @bind-value="poiName" />
           <br />
           <button class="SAVE" @onclick="lineSave">Save</button>
           <button class="DISCARD" @onclick="lineCancel">Cancel</button>

         </div>
       </div>
     break;
    }

    case "CREATEPOLY2":
     {
       <div class="SUBPANEL">
         <div class="SUBPANELHEADER">
           Creating new Line
         </div>
         <div class="SUBPANELBODY">
           Category (Utilizes background color) <br />
           <select @bind="poiSelectedCategory">
             @foreach(POICategory category in categories)
              {
               <option value="@category.name">@category.name</option>
              }
           </select>
           <br />
           Name<br />
           <input type="text" @bind-value="poiName" />
           <br />
           <button class="SAVE" @onclick="polySave">Save</button>
           <button class="DISCARD" @onclick="polyCancel">Cancel</button>

         </div>
       </div>
     break;
    }

    case "DELPOI":
    {
      <div class="SUBPANEL">
         <div class="SUBPANELHEADER">
           Deleting Point of Interest @deletePOIItem.poi_name
         </div>
         <div class="SUBPANELBODY">
           Are you sure you want to delete this Point of Interest?<br />
           <button @onclick="cancelDeletePOI">Cancel</button>
           <button class="DISCARD" @onclick="confirmDeletePOI">DELETE POINT OF INTEREST</button>

         </div>
       </div>
     break;
    }
     
   default:
    {
      <gmp-map 
        rendering-type="raster" 
        heading="270" 
        center="@SystemInformation.session.sysLat,@SystemInformation.session.sysLon" 
        zoom="@SystemInformation.session.sysZoom"
        map-id="48d80325ba0e741c57a7e0a4">
        @if (status == "IDLE")
        @foreach(poi point in points)
         {
          <gmp-advanced-marker position="@point.poi_lat,@point.poi_lng" >
            <div class="poiMarker" style="background-color:rgba(@(getbgcolor(point)),.75);color:rgb(@(getfgcolor(point)))" @onclick="() => deletePOI(point.poi_id)" >@point.poi_shortname</div>
          </gmp-advanced-marker>
         }
         @if (status == "CREATELINE" || status == "CREATEPOLY")
         @foreach(coordinatePair pair in pairList)
         {
          <gmp-advanced-marker position="@pair.lat,@pair.lng" >
            <div class="poiMarker" style="background-color:rgb(175,175,175)">&nbsp;</div>
          </gmp-advanced-marker>
         }
       </gmp-map>
        @if (SystemInformation.mapLoaded == false)
       {
       <script src="@($"https://maps.googleapis.com/maps/api/js?key={SystemInformation.session.googleLink}&callback=initMapEdit&v=weekly&libraries=marker,maps,core")"
              defer></script>
  
       } else
       {
        <script>
          var gmp = document.querySelector("gmp-map");
          var map = gmp.innerMap;


          map.setOptions({
            disableDefaultUI: true,
            gestureHandling: 'all',
            keyboardShortcuts: false
          });

          var mapElementV = document.querySelector("gmp-map");
          var innerMapV = mapElementV.innerMap;

          google.maps.event.addListener(innerMapV, "click", function(event){
              const clickedLocation = event.latLng;
              const latitude = clickedLocation.lat();
              const longitude = clickedLocation.lng();
              DotNet.invokeMethodAsync('Apollo2', 'consumeClick', latitude, longitude);
            });
        </script>
       }

        <script>
          window.initMapEdit = function()
          {
      
            const mapElement1 = document.querySelector("gmp-map");
            const innerMap1 = mapElement1.innerMap;
            DotNet.invokeMethodAsync('Apollo2', 'mapLoaded');

            function applyEditOptions() {
              innerMap1.setOptions({
                disableDefaultUI: true,
                gestureHandling: 'all',
                keyboardShortcuts: false
              });
            }

            google.maps.event.addListenerOnce(innerMap1, "idle", applyEditOptions);
            google.maps.event.addListener(innerMap1, "click", function(event){
              const clickedLocation = event.latLng;
              const latitude = clickedLocation.lat();
              const longitude = clickedLocation.lng();
              DotNet.invokeMethodAsync('Apollo2', 'consumeClick', latitude, longitude);
            });
          }
      
        </script>
     break;
    }
  }
   
  </div>

  

</div>

@code {

 [Parameter]
 public required Window para { get; set; }

 private string status = "IDLE";

 private static MapEdit reference;

 private List<poi> points = new List<poi>();
 private List<POICategory> categories = new List<POICategory>();

 private List<coordinatePair> pairList = new List<coordinatePair>();
 private struct coordinatePair
 {
  public double lat;
  public double lng;
 }

 private void discard()
 {
  WindowManager.closePage(para);
 }

 protected override async Task OnParametersSetAsync()
 {
  base.OnParametersSet();
  WindowManager.WindowChanged += handleUpdate;
  reference = this;
  await getPOIs();
 }

 private void handleUpdate(windowEvent we)
 {
  StateHasChanged();
  if (we.window == para && (we.type != windowEvent.WindowEventType.opened || we.type != windowEvent.WindowEventType.maximized))
  {
   WindowManager.WindowChanged -= handleUpdate;
  }
 }

 private void createPOI()
 {
  if (status.StartsWith("ERROR"))
   return;
  if (status == "CREATEPOI")
  {
   status = "IDLE";
   StateHasChanged();
   return;
  }
  status = "CREATEPOI";
  StateHasChanged();
  return;
 }

 private void saveLine()
 {
  if (pairList.Count < 2)
  {
   WindowManager.AddModal("WRN", "Failed to save line", "Lines require at least two points.");
   return;
  }
  status = "CREATELINE2";
  StateHasChanged();
 }

 private void createLine()
 {
  if (status.StartsWith("ERROR"))
   return;
  if (status == "CREATELINE")
  {
   status = "IDLE";
   pairList.Clear();
   StateHasChanged();
   return;
  }
  status = "CREATELINE";
  StateHasChanged();
  return;
 }

 private async void lineSave()
 {
  if (string.IsNullOrEmpty(poiName) || string.IsNullOrEmpty(poiSelectedCategory))
  {
   WindowManager.AddModal("WRN", "Error", "All fields are required to create a new Line");
   return;
  }

  try
  {
   Poly poly = new Poly();
   poly.category = poiSelectedCategory;
   poly.name = poiName;
   poly.type = "LINE";
   poly.coordinates = new Dictionary<int, CoordinatePair>();

   for (int i = 0; i < pairList.Count; i++)
   {
    CoordinatePair cp = new CoordinatePair();
    cp.lat = pairList[i].lat;
    cp.lng = pairList[i].lng;
    poly.coordinates.Add(i, cp);
    Console.WriteLine(i);
   }

   CreatePolyRequest cpr = new CreatePolyRequest();
   cpr.session = SystemInformation.session;
   cpr.poly = poly;
   var response = await _http.PostAsJsonAsync<CreatePolyRequest>(SystemInformation.sysURL + $"/API/Map/Map/create/poly", cpr);
   if (!response.IsSuccessStatusCode)
   {
    WindowManager.AddModal("ERR", "Error", "Failed to create the new Line. Please try again.");
    return;
   }
   WindowManager.AddModal("SUC", "POI Created", $"Successfully created Line {poiName}");
   status = "IDLE";
   poiSelectedCategory = "";
   poiName = "";
   pairList.Clear();
   StateHasChanged();
  }
  catch(Exception e)
  {
   WindowManager.AddModal("ERR", "Error", "Failed to create the new Line. Please try again.");
   Console.WriteLine(e);
  }

 }

 private void lineCancel()
 {
  if (status == "CREATELINE2")
  {
   pairList.Clear();
   poiName = "";
   poiSelectedCategory = "";
   status = "IDLE";
   StateHasChanged();
  }
 }




 private void savePoly()
 {
  if (pairList.Count < 3)
  {
   WindowManager.AddModal("WRN", "Failed to save Poly", "Polys require at least three points.");
   return;
  }
  status = "CREATEPOLY2";
  StateHasChanged();
 }

 private void openDelete()
 {
  Window window = new Window();
  window.Title = "Map Object List";
  window.WINDOWTYPE = "MAPOBJ";
  WindowManager.openPage(window);
 }

 private void createPoly()
 {
  if (status.StartsWith("ERROR"))
   return;
  if (status == "CREATEPOLY")
  {
   status = "IDLE";
   pairList.Clear();
   StateHasChanged();
   return;
  }
  status = "CREATEPOLY";
  StateHasChanged();
  return;
 }

 private async void polySave()
 {
  if (string.IsNullOrEmpty(poiName) || string.IsNullOrEmpty(poiSelectedCategory))
  {
   WindowManager.AddModal("WRN", "Error", "All fields are required to create a new Poly");
   return;
  }

  try
  {
   Poly poly = new Poly();
   poly.category = poiSelectedCategory;
   poly.name = poiName;
   poly.type = "POLYGON";
   poly.coordinates = new Dictionary<int, CoordinatePair>();

   for (int i = 0; i < pairList.Count; i++)
   {
    CoordinatePair cp = new CoordinatePair();
    cp.lat = pairList[i].lat;
    cp.lng = pairList[i].lng;
    poly.coordinates.Add(i, cp);
   }

   CreatePolyRequest cpr = new CreatePolyRequest();
   cpr.session = SystemInformation.session;
   cpr.poly = poly;
   var response = await _http.PostAsJsonAsync<CreatePolyRequest>(SystemInformation.sysURL + $"/API/Map/Map/create/poly", cpr);
   if (!response.IsSuccessStatusCode)
   {
    WindowManager.AddModal("ERR", "Error", "Failed to create the new Poly. Please try again.");
    return;
   }
   WindowManager.AddModal("SUC", "POI Created", $"Successfully created Poly {poiName}");
   status = "IDLE";
   poiSelectedCategory = "";
   poiName = "";
   pairList.Clear();
   StateHasChanged();
  }
  catch(Exception e)
  {
   WindowManager.AddModal("ERR", "Error", "Failed to create the new Poly. Please try again.");
   Console.WriteLine(e);
  }

 }

 private void polyCancel()
 {
  if (status == "CREATEPOLY2")
  {
   pairList.Clear();
   poiName = "";
   poiSelectedCategory = "";
   status = "IDLE";
   StateHasChanged();
  }
 }

 private string poiSelectedCategory = "";
 private string poiName = "";
 private string poiShortName = "";
 private double poiLat = 0;
 private double poiLng = 0;

 private async void poiSave()
 {
  if (string.IsNullOrEmpty(poiName) || string.IsNullOrEmpty(poiShortName) || string.IsNullOrEmpty(poiSelectedCategory))
  {
   WindowManager.AddModal("WRN", "Error", "All fields are required to create a new POI");
   return;
  }
  await createPOI(poiLat, poiLng, poiName, poiShortName, poiSelectedCategory);
 }

 private void poiCancel()
 {
  if (status == "CREATEPOI2")
  {
   poiSelectedCategory = "";
   poiName = "";
   poiShortName = "";
   status = "IDLE";
   StateHasChanged();
  }
 }

 public async Task createPOI(double lat, double lng, string name, string shortname, string category)
 {
  try
  {
   poi POI = new poi();
   POI.poi_category = category;
   POI.poi_name = name;
   POI.poi_shortname = shortname;
   POI.poi_lat = lat;
   POI.poi_lng = lng;

   CreatePOIRequest cpr = new CreatePOIRequest();
   cpr.session = SystemInformation.session;
   cpr.POI = POI;
   var response = await _http.PostAsJsonAsync<CreatePOIRequest>(SystemInformation.sysURL + $"/API/Map/Map/create/poi", cpr);
   if (!response.IsSuccessStatusCode)
   {
    WindowManager.AddModal("ERR", "Error", "Failed to create the new POI. Please try again.");
    return;
   }
   WindowManager.AddModal("SUC", "POI Created", $"Successfully created POI {name}");
   status = "IDLE";
   poiSelectedCategory = "";
   poiName = "";
   poiShortName = "";
   points.Add(POI);
   StateHasChanged();
  }
  catch(Exception e)
  {
   WindowManager.AddModal("ERR", "Error", "Failed to create the new POI. Please try again.");
   Console.WriteLine(e);
  }
 }

 private poi? deletePOIItem = null;

 public void cancelDeletePOI()
 {
  status = "IDLE";
  deletePOIItem = null;
  StateHasChanged();
 }

 public async void confirmDeletePOI()
 {
  try
  {
   if (deletePOIItem == null) return;
   var response = await _http.PostAsJsonAsync<UserSession>(SystemInformation.sysURL + $"/API/Map/Map/delete/poi/{deletePOIItem.poi_id}", SystemInformation.session);
   if (!response.IsSuccessStatusCode)
   {
    WindowManager.AddModal("ERR", "Error", "Failed to delete the POI. Please try again.");
    return;
   }
   WindowManager.AddModal("SUC", "POI Deleted", $"Successfully deleted POI {deletePOIItem.poi_name}");
  }
  catch(Exception e)
  {
   Console.WriteLine(e);
  }

  status = "IDLE";
  points.Remove(deletePOIItem ?? new poi());
  StateHasChanged();
 }

 public void deletePOI(int id)
 {
  status = "DELPOI";
  deletePOIItem = points.FirstOrDefault(p => p.poi_id == id);
  StateHasChanged();
 }


 public void receiveClick(double lat, double lng)
 {
  switch(status)
  {
   default:
    return;
   case "CREATEPOI":
    status = "CREATEPOI2";
    poiLat = lat;
    poiLng = lng;
    StateHasChanged();
    return;
   case "CREATEPOLY":
   case "CREATELINE":
    coordinatePair np = new coordinatePair();
    np.lat = lat;
    np.lng = lng;
    pairList.Add(np);
    StateHasChanged();
    return;
  }

 }

 private string getbgcolor(poi point)
 {
  POICategory? cat = categories.FirstOrDefault(c => c.name == point.poi_category);
  if (cat == null)
   return "255,255,255";
  return cat.bgcolor;
 }
 private string getfgcolor(poi point)
 {
  POICategory? cat = categories.FirstOrDefault(c => c.name == point.poi_category);
  if (cat == null)
   return "0,0,0";
  return cat.color;
 }

 private async Task getPOIs()
 {
  try
  {
   var response = await _http.PostAsJsonAsync<UserSession>(SystemInformation.sysURL + $"/API/Map/Map/get/poi", SystemInformation.session);
   if (!response.IsSuccessStatusCode)
   {
    Console.WriteLine("Response not 200(OK).");
    status = "ERROR GET";
    return;
   }
   List<poi>? retPOI = await response.Content.ReadFromJsonAsync<List<poi>>();
   if (retPOI == null)
   {
    Console.WriteLine("retPOI null.");
    status = "ERROR READ";
    return;
   }
   points = retPOI;

   response = await _http.PostAsJsonAsync<UserSession>(SystemInformation.sysURL + $"/API/Map/Map/get/cat", SystemInformation.session);
   if (!response.IsSuccessStatusCode)
   {
    Console.WriteLine("Response not 200(OK).");
    status = "ERROR GET";
    return;
   }
   List<POICategory>? retCAT = await response.Content.ReadFromJsonAsync<List<POICategory>>();
   if (retCAT == null)
   {
    Console.WriteLine("retCAT null.");
    status = "ERROR READ";
    return;
   }
   categories = retCAT;

   StateHasChanged();
  }
  catch(Exception e)
  {
   Console.WriteLine(e);
  }
 }



 [JSInvokable]
 public async static Task<bool> consumeClick(double lat, double lng)
 {
  Console.WriteLine($"{lat} {lng}");
  reference.receiveClick(lat, lng);
  return true;
 }

 [JSInvokable]
 public async static Task<bool> mapLoaded()
 {
  SystemInformation.mapLoaded = true;
  return true;
 }



}
