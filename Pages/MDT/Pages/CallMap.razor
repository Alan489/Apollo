@using Apollo2.Shared.Sys.Data.Map
@using Apollo2.Sys
@using Apollo2.Sys.Windows
@using Apollo2.Sys.Data
@using Apollo2.Shared.Sys.Data.Incidents
@using Apollo2.Shared.Sys.User
@using Apollo2.Shared.Sys.Data.Units
@using System.Timers
@using System.Text.Json
@inject HttpClient _http
@inject IJSRuntime JSRuntime

@* <link rel="stylesheet" href="/assets/leaflet/leaflet.css" />
<script src="/assets/leaflet/leaflet.js"></script>*@


<div class="BoardRoot">
 <div class="BoardBody">
  <gmp-map 
  rendering-type="raster" 
  heading="270" 
  center="@SystemInformation.session.sysLat,@SystemInformation.session.sysLon" 
  zoom="@SystemInformation.session.sysZoom"
  map-id="48d80325ba0e741c57a7e0a4">
  @foreach(poi point in points)
   {
     <gmp-advanced-marker position="@point.poi_lat,@point.poi_lng" >
      <div class="poiMarker" style="background-color:rgba(@(getbgcolor(point)),.75);color:rgb(@(getfgcolor(point)))">@point.poi_shortname</div>
     </gmp-advanced-marker>
   }
   @foreach(Incident incident in incidents)
   {
    <gmp-advanced-marker position="@incident.lat,@incident.log" >
      <div class="callLabel">INCIDENT</div>
    </gmp-advanced-marker>
   }
  </gmp-map>
 </div>
</div>

<script src="@($"https://maps.googleapis.com/maps/api/js?key={SystemInformation.session.googleLink}&callback=initMap&v=weekly&libraries=marker,maps,core")"
        defer></script>


@code {

 private List<Incident> incidents = new List<Incident>();
 private List<poi> points = new List<poi>();
 private List<POICategory> categories = new List<POICategory>();
 private List<Poly> polys = new List<Poly>();


 protected override async Task OnInitializedAsync()
 {
  //await JSRuntime.InvokeAsync<string>("setMapDefault", , , SystemInformation.session.sysZoom);
  SysTimers.fifteenSecondTimer.Elapsed += tick;
 }


 public async void tick(Object? source, ElapsedEventArgs? e)
 {


  try
  {
   var resp = await _http.PostAsJsonAsync<UserSession>(SystemInformation.sysURL + $"/API/Incidents/Incidents/get/active", SystemInformation.session);

   if (!resp.IsSuccessStatusCode)
   {
    return;
   }

   GetIncidentResponse? gir = null;
   gir = await resp.Content.ReadFromJsonAsync<GetIncidentResponse>();
   if (gir == null)
    return;

   incidents = gir.Incidents ?? new List<Incident>();

  }
  catch(Exception x)
  {
   Console.WriteLine(x);
  }
  await getPOIs();

  StateHasChanged();
 }

 private async Task getPOIs()
 {
  try
  {
   var response = await _http.PostAsJsonAsync<UserSession>(SystemInformation.sysURL + $"/API/Map/Map/get/poi", SystemInformation.session);
   if (!response.IsSuccessStatusCode)
   {
    Console.WriteLine("Response not 200(OK).");
    return;
   }
   List<poi>? retPOI = await response.Content.ReadFromJsonAsync<List<poi>>();
   if (retPOI == null)
   {
    Console.WriteLine("retPOI null.");
    return;
   }
   points = retPOI;

   response = await _http.PostAsJsonAsync<UserSession>(SystemInformation.sysURL + $"/API/Map/Map/get/cat", SystemInformation.session);
   if (!response.IsSuccessStatusCode)
   {
    Console.WriteLine("Response not 200(OK).");
    return;
   }
   List<POICategory>? retCAT = await response.Content.ReadFromJsonAsync<List<POICategory>>();
   if (retCAT == null)
   {
    Console.WriteLine("retCAT null.");
    return;
   }
   categories = retCAT;

   response = await _http.PostAsJsonAsync<UserSession>(SystemInformation.sysURL + $"/API/Map/Map/get/poly", SystemInformation.session);
   if (!response.IsSuccessStatusCode)
   {
    Console.WriteLine("Response not 200(OK).");
    return;
   }
   List<Poly>? retPOL = await response.Content.ReadFromJsonAsync<List<Poly>>();

   if (retPOL == null)
   {
    Console.WriteLine("retCAT null.");
    return;
   }

   foreach (Poly poly in polys)
   {
    //If this is true, this poly has been deleted.
    if (retPOL.FirstOrDefault(p => p.id == poly.id) == null)
    {
     if (poly.type == "LINE")
      await JSRuntime.InvokeAsync<int>("removeLine",poly.id);
     else
      await JSRuntime.InvokeAsync<int>("removePoly",poly.id);
    }
   }

   foreach(Poly poly1 in retPOL)
   {
    //If this is true, this poly is new.
    if (polys.FirstOrDefault(p => p.id == poly1.id) == null)
    {
     POICategory? category = categories.FirstOrDefault(c => c.name == poly1.category);
     if (category == null)
      category = new POICategory();
     poly1.color = category.hexbg;
     if (poly1.type == "LINE")
      await JSRuntime.InvokeAsync<int>("createLine",poly1);
     else
      await JSRuntime.InvokeAsync<int>("createPoly",poly1);
    }
   }

   polys = retPOL;
   

  }
  catch(Exception e)
  {
   Console.WriteLine(e);
  }
 }

  private string getbgcolor(poi point)
 {
  POICategory? cat = categories.FirstOrDefault(c => c.name == point.poi_category);
  if (cat == null)
   return "255,255,255";
  return cat.bgcolor;
 }
 private string getfgcolor(poi point)
 {
  POICategory? cat = categories.FirstOrDefault(c => c.name == point.poi_category);
  if (cat == null)
   return "0,0,0";
  return cat.color;
 }

}
